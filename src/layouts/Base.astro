---
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
const { title = 'Provost Ultrasound Lab', lang = 'en' } = Astro.props;

const nav = [
  { href: '', label: 'Home' },
  { href: 'research', label: 'Research' },
  { href: 'people', label: 'People' },
  { href: 'publications', label: 'Publications' },
  { href: 'publications/codes', label: 'Codes' },
  { href: 'publications/videos', label: 'Videos' },
  { href: 'join', label: 'Join our Team' },
  { href: 'fr', label: 'Français' },
  { href: 'tetris', label: 'Tetris', newTab: true },
  { href: 'ulmaga', label: 'ULMaga', newTab: true },
];

const link = (h) => (h ? `${base}${h}` : base);
const here = Astro.url.pathname.replace(/\/$/, '');
const isActive = (h) => here === link(h).replace(/\/$/, '');
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={link('')}>Provost Ultrasound Lab</a>
      <nav class="site-nav">
        {nav.map((item) => (
          <a
            href={link(item.href)}
            class={isActive(item.href) ? 'active' : ''}
            target={item.newTab ? '_blank' : undefined}
            rel={item.newTab ? 'noopener' : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </header>

    <main class="content">
      <slot />
    </main>

    <footer class="site-footer">
      <p>Provost Ultrasound Lab &middot; Polytechnique Montréal</p>
    </footer>

    <style is:global>
      :root {
        --accent: #00477b;        /* clean institutional blue */
        --accent-dark: #002f54;
        --ink: #1d2733;
        --muted: #5f6b7a;
        --line: #e3e8ef;
        --maxw: 960px;
        --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: var(--font);
        -webkit-font-smoothing: antialiased;
        color: var(--ink);
        line-height: 1.6;
        background: #fff;
      }
      a { color: var(--accent); }
      .site-header {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 16px 24px;
        border-bottom: 1px solid var(--line);
        max-width: var(--maxw);
        margin: 0 auto;
      }
      .brand {
        font-weight: 700;
        font-size: 18px;
        text-decoration: none;
        color: var(--accent-dark);
        letter-spacing: -0.01em;
      }
      .site-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        font-size: 14px;
      }
      .site-nav a {
        text-decoration: none;
        color: var(--muted);
      }
      .site-nav a:hover { color: var(--accent); }
      .site-nav a.active { color: var(--accent); font-weight: 600; }
      .content {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 32px 24px 64px;
      }
      .content h1 { font-size: 30px; margin-top: 0; color: var(--accent-dark); letter-spacing: -0.01em; }
      .content h2 { font-size: 20px; margin-top: 36px; }
      .site-footer {
        border-top: 1px solid var(--line);
        color: var(--muted);
        font-size: 13px;
        text-align: center;
        padding: 24px;
      }
    </style>
  </body>
</html>
