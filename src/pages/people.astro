---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL;
const slug = (s) => s.normalize('NFKD').replace(/[̀-ͯ]/g, '').replace(/[^a-zA-Z0-9]+/g, '-').replace(/^-|-$/g, '').toLowerCase();

const team = [
  {
    name: 'Jean Provost, Ph.D., ing.',
    body: 'Professor, Department of Engineering Physics. FRQS Research Scholar. IVADO Professor. Member of the Montreal Heart Institute, the UdeM/Poly Biomedical Engineering Institute, IVADO, TransMedTech, the CIHR College of Reviewers, IEEE (Senior), and the Verasonics Scientific Advisory Board. Professor at Polytechnique Montréal since 2018; teaches GBM3805 Physique Moderne pour le Génie Biomédical and PHS3910 Techniques Expérimentales.',
  },
  {
    name: 'Jonathan Porée, Ph.D.',
    body: 'Research Associate, Head of our TransMedTech mobile ultrasound imaging and therapy platform. The platform offers on-site development and deployment of ultrafast ultrasound imaging and therapy tools, tailored to the specific needs of researchers and manufacturers. His research interests are broad but mainly focus at this time on the development of Myocardial Ultrasound Localization Angiography in the beating heart and Transcranial Ultrasound Localization Microscopy. Fellowships by IVADO, TransMedTech.',
  },
  {
    name: 'Stephen A. Lee, Ph.D.',
    body: 'Postdoctoral Scientist. Main research interests include simulations and single capillary reporters, and how they can be used to enhance our understanding of neurovascular processes in neurodegeneration and stroke.',
  },
  {
    name: 'Nin Ghigo, Ph.D.',
    body: 'Postdoctoral Scientist. Main research interests include pulsatility imaging and industrial/governmental collaborations.',
  },
  {
    name: 'Paul Xing',
    body: 'Ph.D. Candidate. Main research interests include transcranial imaging and aberration correction. Scholarships by NSERC, FRQ, TransMedTech.',
  },
  {
    name: 'Oleksandra Gulenko',
    body: 'Ph.D. Candidate, jointly supervised by Prof. Jean Provost and Dr. Abbas Sadikot (McGill). Her research aims to investigate changes in brain vasculature associated with ultrasound-based brain therapies, such as blood–brain barrier opening. Scholarships by FRQ, TransMedTech.',
  },
  {
    name: 'Alice Wu',
    body: 'Ph.D. Candidate, jointly supervised by Prof. Jean Provost and Dr. Michaël Chassé (CHUM). Her research focuses on developing Dynamic Ultrasound Localization Microscopy (DULM) for brain imaging in 3D, with the goal of studying cerebral hemodynamics throughout the cardiac cycle. Scholarships by FRQ, TransMedTech.',
  },
  {
    name: 'Alexis Leconte',
    body: 'Ph.D. Candidate, jointly supervised by Prof. Jean Provost and Dr. Jean-Claude Tardif (Montreal Heart Institute). His research focuses on developing Ultrasound Localization Microscopy (ULM) for imaging the myocardium, aiming to visualize and quantify microvascular blood flow in the beating heart wall. Scholarships by FRQ, TransMedTech.',
  },
  {
    name: 'Cai Jie',
    body: 'Intern. Works toward the development of 4D spatiotemporal tracking. Scholarship from NSERC.',
  },
  {
    name: 'Marco Pontrelli',
    body: 'Intern. Works toward the development of aberration correction in transmit. Scholarship from NSERC.',
  },
  {
    name: 'Malo Rossetto',
    body: 'Intern. Works toward track-based graph representation of the entire brain vasculature.',
  },
  {
    name: 'Ludovic Goetz',
    body: 'Intern. Works toward voxel-wise speed-of-sound correction when imaging using a row-column array probe.',
  },
  {
    name: 'David Bracco, MD',
    body: 'Collaborator. Works toward high-frequency imaging of the heart intramyocardial vasculature.',
  },
];

const alumni = [
  { name: 'Vincent Perrot, Ph.D.', body: 'Postdoctoral Scientist, 2020–2022. Now Senior Research Scientist at DarkVision.' },
  { name: 'Chloé Bourquin, Ph.D.', body: "Provostlab's (first!) Ph.D. student. Scholarships by FRQ, TransMedTech. Now Journalist at La Presse." },
  { name: 'Brice Rauby, Ph.D.', body: 'Member of MILA, jointly supervised by Prof. Jean Provost and Dr. Maxime Gasse (MILA). His research investigated novel deep learning–based methods for Ultrasound Localization Microscopy (ULM), with particular emphasis on three-dimensional extension and in vivo applicability. Scholarships by IVADO, FRQ, TransMedTech. Now at SoundBlade Medical.' },
  { name: 'Samuel Desmarais, M.Sc.A.', body: 'Thesis Masters 2021–2023; Intern 2019–2021. Now Ph.D. Candidate at TU Delft.' },
  { name: 'Olivier Caron, M.Sc.A.', body: "Thesis Masters 2021–2023; Intern 2020–2021. Now Chargé d'étude at Atelier 7Hz." },
  { name: 'Hatim Belgharbi, M.Sc.A.', body: 'Thesis Masters 2020–2021; Intern 2018–2019. Now Ph.D. Candidate at UNC Chapel Hill.' },
  { name: 'Michael Mougharbel, M.Sc.A.', body: 'Thesis Masters 2021–2023. Now QA engineer at the Montreal Heart Institute.' },
  { name: 'Simon Blais, M.Sc.A.', body: 'Thesis Masters 2019–2020. Now Concepteur Mécanique at CLEIO.' },
  { name: 'Erwan Hardy, M.Sc.A.', body: 'Thesis Masters 2019–2020. Now R&D engineer at Quantel Medical.' },
  { name: 'Philippe Cormier, M.Sc.A.', body: 'Thesis Masters 2019–2020. Now R&D engineer at Puzzle Medical.' },
  { name: 'Simon Desrochers', body: 'Intern 2024.' },
  { name: 'Pierre-Olivier Bouchard', body: 'Intern 2024.' },
  { name: 'Louis Caron', body: 'Intern 2024.' },
  { name: 'Emma Gauvreau', body: 'Intern 2024.' },
  { name: 'Théodore Brierre', body: 'Intern 2024.' },
  { name: 'Michael Mayerhofer', body: 'Intern 2022–2024.' },
  { name: 'Baptiste Didier', body: 'Intern 2023.' },
  { name: 'Jean Ropert', body: 'Intern 2023.' },
  { name: 'Tim Whittaker', body: 'Intern 2022.' },
  { name: 'Aurélie Roseberry', body: 'Intern 2022.' },
  { name: 'Juliette Reydet', body: 'Intern 2022.' },
  { name: 'Léo Milecki', body: 'Intern 2019; Visiting Scientist 2022.' },
  { name: 'David Arsenault-Belley', body: 'Intern 2021.' },
  { name: 'Yangou Dou', body: 'Intern 2021.' },
  { name: 'Julie Lanthier', body: 'Intern 2021.' },
  { name: 'Thomas Ricard', body: 'Intern 2021.' },
  { name: 'Tom Quelin', body: 'Intern 2021.' },
  { name: 'Jacynthe Francoeur', body: 'Intern 2019–2020.' },
  { name: 'Élodie Labrecque Langlais', body: 'Intern 2020.' },
  { name: 'Jean-François Martin', body: 'Intern 2019–2020.' },
  { name: 'William Beaulieu', body: 'Intern 2020–2021.' },
  { name: 'Arthur Le Ber', body: 'Intern 2019.' },
  { name: 'Maxence Laplante-Berthier', body: 'Intern (2025–2026). Worked toward validation of ultrasound localization microscopy maps against simulations. Scholarships from NSERC, UPIR.' },
  { name: 'Valentin Jourdan', body: 'Intern (2025–2026). Worked toward the automatic labelling of ultrasound localization microscopy vasculature.' },
  { name: 'Naomi Babii', body: 'Intern (2025–2026). Worked toward validation of ultrasound localization microscopy maps against histology. Scholarships from NSERC, UPIR, FRQ.' },
];
---
<Base title="People — Provost Ultrasound Lab">
  <h1>People</h1>

  <h2>Team</h2>
  {team.map((p) => (
    <div class="person">
      <img class="avatar" src={`${base}people/${slug(p.name)}.jpg`} alt={p.name} loading="lazy" width="72" height="72" />
      <div>
        <div class="person-name">{p.name}</div>
        <p class="person-body">{p.body}</p>
      </div>
    </div>
  ))}

  <h2>Alumni</h2>
  {alumni.map((p) => (
    <div class="person">
      <img class="avatar" src={`${base}people/${slug(p.name)}.jpg`} alt={p.name} loading="lazy" width="72" height="72" />
      <div>
        <div class="person-name">{p.name}</div>
        <p class="person-body">{p.body}</p>
      </div>
    </div>
  ))}

  <style>
    h2 {
      color: var(--accent-dark);
      border-bottom: 1px solid var(--line);
      padding-bottom: 6px;
    }
    .person { display: flex; gap: 14px; align-items: flex-start; margin-bottom: 18px; }
    .avatar {
      width: 72px;
      height: 72px;
      border-radius: 10px;
      object-fit: cover;
      flex-shrink: 0;
      background: #eef1f5;
    }
    .person-name { font-weight: 600; }
    .person-body {
      margin: 2px 0 0;
      color: var(--muted);
      font-size: 15px;
    }
  </style>
</Base>
